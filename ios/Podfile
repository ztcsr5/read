platform :ios, '13.0'

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

# ---------------------------------------------------------
# Pre-install hook to copy quickjs_engine cxx files into its ios folder and update podspec
# because CocoaPods cannot resolve source_files with '..' (outside the pod directory).
# ---------------------------------------------------------
require 'json'
require 'fileutils'

plugins_file = File.expand_path('../../.flutter-plugins-dependencies', __FILE__)
if File.exist?(plugins_file)
  begin
    data = JSON.parse(File.read(plugins_file))
    quickjs_plugin = data.dig('plugins', 'ios')&.find { |p| p['name'] == 'quickjs_engine' }
    if quickjs_plugin
      quickjs_engine_dir = quickjs_plugin['path']
      puts "[Podfile] Found quickjs_engine plugin at: #{quickjs_engine_dir}"
      
      # 1. Copy native/cxx to ios/cxx
      native_cxx = File.expand_path('native/cxx', quickjs_engine_dir)
      ios_cxx = File.expand_path('ios/cxx', quickjs_engine_dir)
      
      if File.exist?(native_cxx)
        puts "[Podfile] Copying native/cxx to ios/cxx..."
        FileUtils.rm_rf(ios_cxx)
        FileUtils.mkdir_p(ios_cxx)
        FileUtils.cp_r(File.join(native_cxx, '.'), ios_cxx)
      else
        puts "[Podfile] Warning: native/cxx not found at #{native_cxx}"
      end
      
      # 2. Overwrite quickjs_engine.podspec in ios folder to use local files
      podspec_path = File.expand_path('ios/quickjs_engine.podspec', quickjs_engine_dir)
      if File.exist?(podspec_path)
        puts "[Podfile] Overwriting quickjs_engine.podspec to use local source paths..."
        podspec_content = <<~'PODSPEC'
          # Overwritten by Podfile to resolve CocoaPods sandbox and parent path issues.
          Pod::Spec.new do |s|
            s.name             = 'quickjs_engine'
            s.version          = '0.1.0'
            s.summary          = 'quickjs-ng bridge for full_svg_flutter.'
            s.description      = 'Forked from flutter_js. Bundles quickjs-ng 0.14.0 directly.'
            s.homepage         = 'https://github.com/denisnadey/flutter_full_svg_support'
            s.license          = { :type => 'MIT' }
            s.author           = { 'Denis Nadey' => 'denis.nadey@gmail.com' }
            s.source           = { :path => '.' }

            s.source_files = [
              'Classes/**/*.{swift,h,m}',
              'cxx/libfastdev_quickjs_runtime.cpp',
              'cxx/quickjs/quickjs.c',
              'cxx/quickjs/libregexp.c',
              'cxx/quickjs/libunicode.c',
              'cxx/quickjs/dtoa.c',
              'cxx/quickjs/*.h'
            ]
            s.public_header_files = []

            s.dependency 'Flutter'
            s.platform = :ios, '11.0'
            s.swift_version = '5.0'

            s.pod_target_xcconfig = {
              'DEFINES_MODULE' => 'YES',
              'CLANG_CXX_LANGUAGE_STANDARD' => 'c++17',
              'GCC_C_LANGUAGE_STANDARD' => 'c11',
              'CLANG_ENABLE_MODULES' => 'YES',
              'HEADER_SEARCH_PATHS' => '"$(PODS_TARGET_SRCROOT)/cxx" "$(PODS_TARGET_SRCROOT)/cxx/quickjs"',
              'GCC_PREPROCESSOR_DEFINITIONS' => 'CONFIG_VERSION=\"ng-0.14.0\" $(inherited)',
              'WARNING_CFLAGS' => '-Wno-unused-function -Wno-unused-variable -Wno-unused-parameter -Wno-unused-but-set-variable',
            }
          end
        PODSPEC
        File.write(podspec_path, podspec_content)
        puts "[Podfile] Overwrite of quickjs_engine.podspec successful."
      else
        puts "[Podfile] Warning: quickjs_engine.podspec not found at #{podspec_path}"
      end
    else
      puts "[Podfile] quickjs_engine plugin not found in ios plugins list."
    end
  rescue => e
    puts "[Podfile] Error during quickjs_engine pre-install patching: #{e}"
  end
else
  puts "[Podfile] Warning: .flutter-plugins-dependencies not found at #{plugins_file}"
end

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. Run flutter pub get first."
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise 'FLUTTER_ROOT not found in Generated.xcconfig.'
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks! :linkage => :static
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end

  # 一次性修补:让 quickjs_engine 的 C bridge 符号在 iOS 静态链接下不被 strip。
  # 现象:运行时 dlsym(RTLD_DEFAULT, jsNewRuntime) 返回 symbol not found,所有 @js/<js> 源超时。
  # 根因:libfastdev_quickjs_runtime.cpp 里的 jsNewRuntime/jsNewContext 等函数没有
  #       Swift/ObjC 引用,链接器 dead-code elimination 把符号砍掉。-Wl,-u,_xxx 强制保留。
  #
  # 必须同时加到:
  #   1) pods project (quickjs_engine target 自身编译)
  #   2) aggregate target (Runner.xcodeproj 静态链 quickjs_engine 的 .a 时)
  # 缺一不可,否则 dlsym 仍报 symbol not found。
  #
  # 注意:符号名必须跟 C 端 extern "C" 函数名精确匹配!
  # C 端 libfastdev_quickjs_runtime.cpp 里实际叫 jsCall / jsEval,不是
  # jsCallFunction / jsEvalFunction(后者根本不存在,加进 -u 列表会
  # 让链接器报 Undefined symbol)。
  quickjs_keep_symbols = %w[
    _jsNewRuntime
    _JS_NewRuntimeDartBridge
    _jsNewContext
    _jsFreeRuntime
    _jsFreeContext
    _jsCall
    _jsEval
    _doReturnOne
  ]

  # 1) 加到 quickjs_engine pod target 自己的 OTHER_LDFLAGS
  installer.pods_project.targets.each do |target|
    if target.name == 'quickjs_engine' || target.name == 'quickjs_engine_ios' || target.name.start_with?('quickjs_engine')
      target.build_configurations.each do |config|
        ldflags = config.build_settings['OTHER_LDFLAGS'] || ['$(inherited)']
        ldflags = [ldflags] unless ldflags.is_a?(Array)
        quickjs_keep_symbols.each do |sym|
          flag = "-Wl,-u,#{sym}"
          ldflags << flag unless ldflags.include?(flag)
        end
        config.build_settings['OTHER_LDFLAGS'] = ldflags
        # 同时让链接器不过度 strip
        # 关键:必须 NO。YES 让 iOS 链接器无视 __attribute__((used)) 把
        # 没人直接调用的函数砍掉,导致 -Wl,-u,_xxx 找不到符号。
        config.build_settings['DEAD_CODE_STRIPPING'] = 'NO'
        config.build_settings['STRIP_INSTALLED_PRODUCT'] = 'NO'
      end
    end
  end

  # 2) 加到 main app (Runner) target 的 OTHER_LDFLAGS
  #    CocoaPods 的 aggregate_target.user_project 就是 Runner.xcodeproj
  installer.aggregate_targets.each do |aggregate_target|
    aggregate_target.user_project.native_targets.each do |native_target|
      native_target.build_configurations.each do |config|
        ldflags = config.build_settings['OTHER_LDFLAGS'] || ['$(inherited)']
        ldflags = [ldflags] unless ldflags.is_a?(Array)
        quickjs_keep_symbols.each do |sym|
          flag = "-Wl,-u,#{sym}"
          ldflags << flag unless ldflags.include?(flag)
        end
        config.build_settings['OTHER_LDFLAGS'] = ldflags
        config.build_settings['DEAD_CODE_STRIPPING'] = 'NO'
        config.build_settings['STRIP_INSTALLED_PRODUCT'] = 'NO'
      end
    end
    aggregate_target.user_project.save
  end
end
